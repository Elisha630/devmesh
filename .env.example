# DevMesh Environment Configuration
# Copy this file to .env and customize as needed

# Server Configuration
DEVMESH_WS_HOST=127.0.0.1
DEVMESH_WS_PORT=7700
DEVMESH_HTTP_PORT=7701
DEVMESH_DASHBOARD_PORT=7702

# Hardware Limits
DEVMESH_GPU_VRAM_GB=16
DEVMESH_RAM_GB=32

# Timeouts
DEVMESH_LOCK_TTL_SEC=15
DEVMESH_HEARTBEAT_GRACE_SEC=5
DEVMESH_AGENT_RECONNECT_GRACE_SEC=30
DEVMESH_HEARTBEAT_INTERVAL_SEC=4
DEVMESH_CLI_VERSION_TIMEOUT_SEC=3
DEVMESH_CLI_INVOKE_TIMEOUT_SEC=120

# Logging
DEVMESH_LOG_LEVEL=INFO
# DEVMESH_LOG_FILE=logs/devmesh.log

# Dashboard
DEVMESH_AUTO_OPEN_BROWSER=true
DEVMESH_HARDWARE_SAMPLE_INTERVAL_SEC=2
DEVMESH_HARDWARE_HISTORY_LEN=120

# Conflict Resolution
DEVMESH_CONFLICT_RESOLVE_COOLDOWN_SEC=15

# Agent-specific settings
DEVMESH_AGENT_HEARTBEAT_SEC=4
DEVMESH_AGENT_CLI_TIMEOUT_SEC=240
DEVMESH_AGENT_PING_INTERVAL_SEC=20

# Tool-specific overrides
# DEVMESH_GEMINI_MODEL=gemini-2.0-flash
